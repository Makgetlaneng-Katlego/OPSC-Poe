<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    >

 <LinearLayout
     android:layout_marginTop="35dp"
     android:layout_marginHorizontal="15dp"
     android:background="@drawable/card_background"
     android:orientation="vertical"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:elevation="10dp">

    <!-- Header with Back Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBackCreateAcc"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/baseline_arrow_back_24"
            android:onClick="LogoutBtn"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/app_name"
            android:textColor="@color/primaryTextColor"
            android:textSize="24sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:layout_marginVertical="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your fullname:"
        android:textColor="@color/SecondaryText"
        android:layout_marginStart="33dp"
        android:textSize="25sp"/>
    <EditText
        android:id="@+id/etFullName"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="20sp"
        android:textAppearance="@color/primaryTextColor"
        android:layout_marginHorizontal="15dp"
        android:textColorHint="@color/InputboxColor"
        android:hint=" e.g Alex Johnson"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:inputType="text"
        android:layout_marginBottom="10dp"
        android:importantForAutofill="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your email"
        android:textColor="@color/SecondaryText"
        android:layout_marginStart="33dp"
        android:textSize="25sp"
        android:layout_marginBottom="15dp"/>
    <EditText
        android:id="@+id/etEmail"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="20sp"
        android:textAppearance="@color/primaryTextColor"
        android:layout_marginHorizontal="15dp"
        android:textColorHint="@color/InputboxColor"
        android:hint="  hello@example.co.za"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="10dp"
        android:importantForAutofill="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="25sp"
        android:layout_marginStart="33dp"
        android:textColor="@color/SecondaryText"
        android:text="Enter your password:"
        android:layout_marginBottom="10dp"/>
    <EditText
        android:id="@+id/etPassword1"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="15sp"
        android:textAppearance="@color/InputboxColor"
        android:layout_marginHorizontal="15dp"
        android:inputType="textPassword"
        android:hint=" ********"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:importantForAutofill="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="25sp"
        android:layout_marginStart="33dp"
        android:textColor="@color/SecondaryText"
        android:text="Confirm your password:"
        android:layout_marginBottom="15dp"/>
    <EditText
        android:id="@+id/etPassword"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="15sp"
        android:textAppearance="@color/InputboxColor"
        android:layout_marginHorizontal="15dp"
        android:inputType="textPassword"
        android:hint=" ********"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:importantForAutofill="no"/>
    <Button
        android:id="@+id/LogButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:textAlignment="center"
        android:textSize="30sp"
        android:text="Create Account"
        android:textColor="@color/button_primary_text"
        android:background="@drawable/button_rounded_corners"
        android:backgroundTint="@color/primaryTextColor"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="45dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="RegisterBtn"
        />
 </LinearLayout>
</ScrollView>