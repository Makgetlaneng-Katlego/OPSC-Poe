<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/baseline_arrow_back_24"
            android:onClick="IncomePage"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Add Income"
            android:textColor="@color/primaryTextColor"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Form Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount (ZAR)"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/add_income_input_bg"
            android:hint="R0.00"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:textColor="@color/text_muted"
            android:textSize="32sp"
            android:textStyle="bold"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp"/>

        <!-- Source Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Source Name"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etSourceName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/add_income_input_bg"
            android:hint="e.g. Salary, Bonus"
            android:paddingHorizontal="20dp"
            android:textColor="@color/primaryTextColor"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/chip_selected_bg"
                android:text="Salary"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1.2"
                android:background="@drawable/chip_unselected_bg"
                android:text="Freelance"
                android:textColor="@color/primaryTextColor"
                android:gravity="center"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:background="@drawable/chip_unselected_bg"
                android:text="Gift"
                android:textColor="@color/primaryTextColor"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/add_income_input_bg"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="2026/04/08"
                android:textColor="@color/primaryTextColor"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/baseline_calendar_today_24"
                android:alpha="0.6"/>
        </RelativeLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveIncome"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/button_green_rounded"
            android:text="Save Income"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:onClick="SaveIncome"
            android:backgroundTint="@null" />

    </LinearLayout>

</LinearLayout>
