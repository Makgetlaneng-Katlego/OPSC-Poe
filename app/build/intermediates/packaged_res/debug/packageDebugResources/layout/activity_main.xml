<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:layout_margin="10dp"
    >

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/in_app_logo"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:contentDescription="@string/app_name"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:id="@+id/TextView"
        android:textSize="50sp"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="30dp"
        android:textColor="@color/primaryTextColor"
        android:text="@string/app_name"
        android:textAlignment="center"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="manage your wealth simply"
        android:textColor="@color/SecondaryText"
        android:textAlignment="center"
        android:textSize="20sp"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:id="@+id/EmailTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your email:"
        android:textColor="@color/SecondaryText"
        android:textSize="25sp"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/EdiText"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="20sp"
        android:textAppearance="@color/primaryTextColor"
        android:layout_marginHorizontal="15dp"
        android:textColorHint="@color/InputboxColor"
        android:hint="  hello@example.co.za"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:inputType="text"
        android:layout_marginBottom="10dp"
        android:importantForAutofill="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="25sp"
        android:layout_marginStart="15dp"
        android:textColor="@color/SecondaryText"
        android:text="Enter your password:"
        android:layout_marginBottom="10dp"/>
    <EditText
        android:id="@+id/EditText"
        android:layout_height="60dp"
        android:layout_width="match_parent"
        android:textSize="15sp"
        android:textAppearance="@color/InputboxColor"
        android:layout_marginHorizontal="15dp"
        android:inputType="textPassword"
        android:hint=" ********"
        android:background="@drawable/input_box_rounded_corners"
        android:backgroundTint="@color/SecondaryText"
        android:importantForAutofill="no"/>
    <Button
        android:id="@+id/LogButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:textAlignment="center"
        android:textSize="30sp"
        android:text="Login"
        android:textColor="@color/button_primary_text"
        android:background="@drawable/button_rounded_corners"
        android:backgroundTint="@color/primaryTextColor"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="45dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="LoginBtn"
        />
    <com.google.android.material.button.MaterialButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Account"
        android:textColor="@color/primaryTextColor"
        app:backgroundTint="@color/card_bg"
        app:strokeColor="@color/button_primary_bg"
        app:strokeWidth="2dp"
        app:cornerRadius="30dp"
        android:layout_marginHorizontal="45dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="createAcc"
        android:layout_marginBottom="30dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        />
</LinearLayout>