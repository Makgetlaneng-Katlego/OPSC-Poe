<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_marginTop="25dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:layout_marginBottom="32dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@drawable/baseline_arrow_back_24"
            android:onClick="SpendingLimitsPage"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Set Spending Limit"
            android:textColor="@color/primaryTextColor"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Form Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spBudgetCategory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/add_income_input_bg"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown"
            android:entries="@array/budget_categories" />

        <!-- Amount -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Limit Amount (ZAR)"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etBudgetAmount"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/add_income_input_bg"
            android:hint="2000"
            android:paddingHorizontal="20dp"
            android:textColor="@color/primaryTextColor"
            android:textSize="16sp"
            android:inputType="numberDecimal"
            android:layout_marginBottom="24dp"/>

        <!-- Period -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Period"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgBudgetPeriod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbMonthly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monthly"
                android:checked="true"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/rbWeekly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly" />
        </RadioGroup>

        <!-- Alert -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert when spending exceeds"
            android:textColor="@color/primaryTextColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spBudgetAlert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/add_income_input_bg"
            android:layout_marginBottom="32dp"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown"
            android:entries="@array/alert_percentages" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveBudget"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/button_green_rounded"
            android:text="Save Spending Limit"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:onClick="SaveSpendingLimit"
            app:backgroundTint="@null" />

    </LinearLayout>

</LinearLayout>
